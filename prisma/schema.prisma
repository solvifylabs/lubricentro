generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Categoria {
  id        String     @id @default(cuid())
  name      String     @unique
  products  Producto[]
  createdAt DateTime   @default(now())
}

model Marca {
  id        String     @id @default(cuid())
  name      String     @unique
  products  Producto[]
  createdAt DateTime   @default(now())
}

model Producto {
  id             String              @id @default(cuid())
  name           String
  code           String?             @unique
  categoryId     String
  category       Categoria           @relation(fields: [categoryId], references: [id])
  brandId        String?
  brand          Marca?              @relation(fields: [brandId], references: [id])
  buyPrice       Decimal             @db.Decimal(10, 2)
  sellPrice      Decimal             @db.Decimal(10, 2)
  stock          Int                 @default(0)
  minStock       Int                 @default(5)
  unit           String              @default("unidad")
  active         Boolean             @default(true)
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt
  stockMovements             MovimientoStock[]
  saleItems                  DetalleVenta[]
  serviceItems               ServicioProducto[]
  supplierLinks              ProveedorProducto[]
  sesionProducts             SesionProducto[]
  expectedConsumptionPerWash Decimal?              @db.Decimal(10, 4)
}

model MovimientoStock {
  id        String   @id @default(cuid())
  productId String
  product   Producto @relation(fields: [productId], references: [id])
  type      String   // "entry" | "exit" | "adjustment"
  quantity  Int
  reason    String?
  createdAt DateTime @default(now())
}

model Cliente {
  id        String     @id @default(cuid())
  firstName String
  lastName  String?
  phone     String?
  email     String?
  dni       String?
  active    Boolean    @default(true)
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  vehicles  Vehiculo[]
  services  Servicio[]
  sales     Venta[]
}

model Vehiculo {
  id        String     @id @default(cuid())
  plate     String     @unique
  brand     String
  model     String
  year      Int?
  engine    String?
  clientId  String?
  client    Cliente?   @relation(fields: [clientId], references: [id])
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  services  Servicio[]
}

model Servicio {
  id              String             @id @default(cuid())
  clientId        String?
  client          Cliente?           @relation(fields: [clientId], references: [id])
  vehicleId       String
  vehicle         Vehiculo           @relation(fields: [vehicleId], references: [id])
  mileage         Int?
  nextServiceKm   Int?
  serviceDate     DateTime           @default(now())
  nextServiceDate DateTime?
  amount          Decimal            @db.Decimal(10, 2)
  notes           String?
  createdAt       DateTime           @default(now())
  products        ServicioProducto[]
}

model ServicioProducto {
  id        String   @id @default(cuid())
  serviceId String
  service   Servicio @relation(fields: [serviceId], references: [id])
  productId String
  product   Producto @relation(fields: [productId], references: [id])
  quantity  Int
  price     Decimal  @db.Decimal(10, 2)
}

model Venta {
  id        String         @id @default(cuid())
  clientId  String?
  client    Cliente?       @relation(fields: [clientId], references: [id])
  total     Decimal        @db.Decimal(10, 2)
  discount  Decimal        @default(0) @db.Decimal(10, 2)
  status    String         @default("completed") // "completed" | "cancelled"
  createdAt DateTime       @default(now())
  items     DetalleVenta[]
}

model DetalleVenta {
  id        String   @id @default(cuid())
  saleId    String
  sale      Venta    @relation(fields: [saleId], references: [id])
  productId String
  product   Producto @relation(fields: [productId], references: [id])
  quantity  Int
  price     Decimal  @db.Decimal(10, 2)
}

model Proveedor {
  id           String              @id @default(cuid())
  name         String
  contactName  String?
  phone        String?
  email        String?
  address      String?
  active       Boolean             @default(true)
  createdAt    DateTime            @default(now())
  updatedAt    DateTime            @updatedAt
  productLinks ProveedorProducto[]
  purchases    Compra[]
}

model ProveedorProducto {
  id         String    @id @default(cuid())
  supplierId String
  supplier   Proveedor @relation(fields: [supplierId], references: [id])
  productId  String
  product    Producto  @relation(fields: [productId], references: [id])

  @@unique([supplierId, productId])
}

model Compra {
  id         String    @id @default(cuid())
  supplierId String
  supplier   Proveedor @relation(fields: [supplierId], references: [id])
  total      Decimal   @db.Decimal(10, 2)
  notes      String?
  createdAt  DateTime  @default(now())
}

model ConfigLavaAuto {
  id        String   @id @default(cuid())
  washPrice Decimal  @db.Decimal(10, 2)
  updatedAt DateTime @updatedAt
}

model TurnoLavaAuto {
  id        String           @id @default(cuid())
  date      DateTime         @db.Date
  startedAt DateTime         @default(now())
  endedAt   DateTime?
  notes     String?
  sessions  SesionLavaAuto[]
  createdAt DateTime         @default(now())
}

model SesionLavaAuto {
  id          String           @id @default(cuid())
  plate       String?
  amount      Decimal          @db.Decimal(10, 2)
  notes       String?
  sessionDate DateTime         @default(now())
  turnoId     String?
  turno       TurnoLavaAuto?   @relation(fields: [turnoId], references: [id])
  products    SesionProducto[]
  createdAt   DateTime         @default(now())
}

model SesionProducto {
  id        String         @id @default(cuid())
  sessionId String
  session   SesionLavaAuto @relation(fields: [sessionId], references: [id])
  productId String
  product   Producto       @relation(fields: [productId], references: [id])
  quantity  Int
}
